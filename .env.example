# 3Maps — Environment Variables
# Copy this file to .env and fill in the values

# -----------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------
PORT=8787
NODE_ENV=development

# -----------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------
# JWT secret (auto-generated if not set, stored in data/.auth_secret)
# AUTH_SECRET=your-secret-here

# -----------------------------------------------------------------------
# Email (SMTP) — for password recovery
# -----------------------------------------------------------------------
# Gmail example:
#   1. Enable 2FA on your Google account
#   2. Generate an App Password at https://myaccount.google.com/apppasswords
#   3. Use your Gmail address as SMTP_USER and the App Password as SMTP_PASS

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=leoaalvs@gmail.com
SMTP_PASS=your-gmail-app-password-here
SMTP_FROM=3Maps <leoaalvs@gmail.com>

# Base URL of the app (used in email links)
APP_URL=http://localhost:5173

# -----------------------------------------------------------------------
# Firebase Auth (login com e-mail/senha e Google)
# -----------------------------------------------------------------------
# Backend: caminho para o JSON da conta de serviço (Firebase Console > Project settings > Service accounts)
# FIREBASE_SERVICE_ACCOUNT_PATH=./server/firebase-service-account.json

# Frontend (obrigatório para login Firebase): Firebase Console > Project settings > General > Your apps > SDK setup
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_APP_ID=
# Opcionais (defaults usam projectId maps-dc9df):
# VITE_FIREBASE_PROJECT_ID=maps-dc9df
# VITE_FIREBASE_AUTH_DOMAIN=maps-dc9df.firebaseapp.com
# VITE_FIREBASE_STORAGE_BUCKET=maps-dc9df.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=

# -----------------------------------------------------------------------
# Data storage
# -----------------------------------------------------------------------
# DATA_DIR=./data
# STATIC_DIR=./dist

# -----------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:4173
